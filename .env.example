# Example environment configuration.
#
# Copy this file to ".env" and adjust as needed:
#     cp .env.example .env
#
# The API auto-loads ".env" on startup (via python-dotenv), so values you set
# here take effect when the app starts. Real environment variables always win
# over .env. Every value has a sensible default in code, so the app also runs
# with no .env at all. The real ".env" is gitignored.
# ---------------------------------------------------------------------------


# === API: model loading ====================================================

# Root directory that contains the "teacher_model/" and "student_model/" folders.
# Local default: the repo's ./models. On Lambda this is /var/task/models.
MODELS_DIR=./models

# Override individual model paths only if they live outside MODELS_DIR.
# TEACHER_MODEL_PATH=./models/teacher_model
# STUDENT_MODEL_PATH=./models/student_model


# === API: inference behavior ===============================================

# Max token length per review. Must match training (the notebook used 128).
MAX_LENGTH=128

# Where to run inference: "cpu" (Lambda, most laptops) or "cuda" (GPU box).
INFERENCE_DEVICE=cpu

# Reject prediction requests with more than this many texts (returns HTTP 413).
MAX_BATCH_SIZE=32

# PyTorch intra-op threads. 0 = let PyTorch decide. On Lambda, pin this to the
# number of vCPUs your memory size grants (~1 vCPU per 1769 MB).
TORCH_NUM_THREADS=0

# If "true", both models load at startup (slower start, fast first request).
# If "false", each model loads lazily on its first request.
PRELOAD_MODELS=false


# === API: logging ==========================================================

# Python log level: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO


# === Lambda Web Adapter (container runtime only) ===========================
# These are set in the Dockerfile and only matter inside the container.

# PORT=8080
# AWS_LWA_READINESS_CHECK_PATH=/health
# AWS_LWA_INVOKE_MODE=buffered


# === Deployment (used by the Makefile and Terraform) =======================
# The Makefile reads these from your shell, not from this .env file. They are
# listed here for reference. Override on the command line, e.g.:
#     make push-ecr AWS_REGION=us-east-1 IMAGE_TAG=v2

# AWS region to deploy into.
AWS_REGION=ap-southeast-1

# Project name. Used for the ECR repo, Lambda function, and image tags.
PROJECT_NAME=filipino-sentiment

# Container image tag to build, push, and deploy.
IMAGE_TAG=latest

# Host port that "make test" checks (the container is published on :9000).
TEST_PORT=9000
